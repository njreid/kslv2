/- kdl-version 2

// Illustrative KSL schema for a KDL-native TwiML Voice-like DSL.
// This is based on Twilio's public TwiML Voice documentation, not an official XSD.
// No published TwiML XSD was found at the obvious documentation endpoints.
schema "https://example.com/schemas/twiml-voice-kdl" version="0.1.0" {
  info title="TwiML Voice KDL Schema" description="Illustrative KSL schema for a KDL-native rendition of core TwiML Voice concepts"

  define "http-method" {
    value {
      type string
      enum GET POST
      doc:summary "HTTP method accepted by Twilio callback-related attributes"
    }
  }

  define "url-string" {
    value {
      type string
      format url-reference
      doc:summary "Relative or absolute URL"
    }
  }

  define "input-mode" {
    value {
      type string
      enum dtmf speech "dtmf speech"
      doc:summary "Input mode accepted by Gather"
      doc:example "speech"
      doc:example "dtmf speech"
    }
  }

  define "say-verb" {
    node "Say" {
      doc:summary "Read text to the caller using text-to-speech"
      doc:warning "Some voice and language combinations are invalid or provider-dependent"

      props closed
      prop "language" optional {
        type string
        doc:summary "TTS language such as en-US or en-GB"
      }
      prop "voice" optional {
        type string
        doc:summary "Voice name such as man, woman, or a provider-specific voice identifier"
        doc:example "man"
        doc:example "Polly.Joanna-Generative"
      }
      prop "loop" optional default=1 {
        type integer
        min 0
        doc:summary "Number of repetitions; 0 means loop until hangup or service limit"
      }

      arg 0 required {
        type string
        min-length 1
        doc:summary "Text to speak"
      }

      children closed {}
    }
  }

  define "play-verb" {
    node "Play" {
      doc:summary "Play an audio file to the caller"
      props closed
      arg 0 required {
        type string
        format url-reference
        doc:summary "Audio file URL"
      }
      children closed {}
    }
  }

  define "pause-verb" {
    node "Pause" {
      doc:summary "Pause before executing further instructions"
      props closed
      prop "length" optional default=1 {
        type integer
        min 1
        doc:summary "Pause length in seconds"
      }
      children closed {}
    }
  }

  define "redirect-verb" {
    node "Redirect" {
      doc:summary "Redirect call flow to another TwiML document"
      props closed
      prop "method" optional ref="http-method"
      arg 0 required ref="url-string"
      children closed {}
    }
  }

  define "number-noun" {
    node "Number" {
      doc:summary "Dial a telephone number within Dial"
      props open
      prop "url" optional ref="url-string"
      prop "method" optional ref="http-method"
      prop "sendDigits" optional {
        type string
      }
      prop "statusCallback" optional ref="url-string"
      prop "statusCallbackMethod" optional ref="http-method"
      arg 0 required {
        type string
        min-length 1
        doc:summary "Destination phone number"
      }
      children closed {}
    }
  }

  define "conference-noun" {
    node "Conference" {
      doc:summary "Join or create a named conference room"
      doc:warning "Conference names should not contain personal or sensitive data"
      props open
      arg 0 required {
        type string
        min-length 1
        doc:summary "Conference room name"
      }
      children closed {}
    }
  }

  define "dial-verb" {
    node "Dial" {
      doc:summary "Connect the current caller to another party"
      props open
      prop "action" optional ref="url-string"
      prop "method" optional ref="http-method"

      any-of {
        arg 0 required {
          type string
          min-length 1
          doc:summary "Inline destination such as a number"
        }
        children closed {
          choice {
            node "Number" many ref="number-noun"
            node "Conference" required ref="conference-noun"
          }
        }
      }
    }
  }

  define "gather-verb" {
    node "Gather" {
      doc:summary "Collect digits, speech, or both"
      props open
      prop "action" optional ref="url-string"
      prop "method" optional ref="http-method"
      prop "input" optional ref="input-mode"
      prop "timeout" optional {
        type integer
        min 1
      }
      prop "numDigits" optional {
        type integer
        min 1
      }
      prop "finishOnKey" optional {
        type string
        doc:summary "One of #, *, a single digit, or the empty string in the XML dialect"
      }
      prop "language" optional {
        type string
      }
      prop "speechModel" optional {
        type string
      }
      prop "actionOnEmptyResult" optional {
        type boolean
      }

      children closed {
        node "Say" many ref="say-verb"
        node "Play" many ref="play-verb"
        node "Pause" many ref="pause-verb"
      }
    }
  }

  define "simple-verb" {
    children closed {
      node "Hangup" optional {
        doc:summary "Terminate the call"
      }
      node "Reject" optional {
        doc:summary "Reject the incoming call"
      }
      node "Leave" optional {
        doc:summary "Remove a caller from a queue"
      }
    }
  }

  document {
    doc:summary "Root TwiML Voice response document rendered into a KDL-native form"
    doc:detail "This example captures a useful documented subset of TwiML Voice. It is not a claim of full Twilio dialect coverage."

    node "Response" required {
      doc:summary "Required root element in TwiML Voice responses"
      children closed {
        node "Say" many ref="say-verb"
        node "Play" many ref="play-verb"
        node "Pause" many ref="pause-verb"
        node "Dial" many ref="dial-verb"
        node "Gather" many ref="gather-verb"
        node "Redirect" many ref="redirect-verb"
        ref "simple-verb"
      }
    }
  }
}
